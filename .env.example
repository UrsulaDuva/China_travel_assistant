# =============================================================================
# China Travel Pro - Environment Configuration Template
# =============================================================================
# 请复制此文件为 .env 并填写实际配置
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_URL=localhost
ORCHESTRATOR_PORT=10001
ORCHESTRATOR_BIND_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# LLM Configuration - DashScope (阿里云 Qwen)
# -----------------------------------------------------------------------------
# 获取 API Key: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-plus

# -----------------------------------------------------------------------------
# LM Studio Configuration (可选 - 本地意图识别)
# -----------------------------------------------------------------------------
# LM Studio 用于本地意图识别，降低 API 调用成本
# 安装: https://lmstudio.ai/
# 启动本地服务器后填写以下配置
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=local-model

# -----------------------------------------------------------------------------
# MCP Services Configuration
# -----------------------------------------------------------------------------

# 墨迹天气 MCP
MOJI_WEATHER_MCP_URL=https://mcp.modelscope.cn/api/v1/servers/@moji/moji-weather-mcp

# 12306 火车票 MCP
RAILWAY_12306_MCP_URL=https://mcp.modelscope.cn/api/v1/servers/@luyuhan520/12306-mcp

# 高德地图 MCP
# 获取 API Key: https://lbs.amap.com/
AMAP_MCP_URL=https://mcp.modelscope.cn/api/v1/servers/@luyuhan520/amap-mcp
AMAP_API_KEY=your_amap_api_key_here

# -----------------------------------------------------------------------------
# Session Configuration
# -----------------------------------------------------------------------------
SESSION_TTL_SECONDS=86400
SESSION_CLEANUP_INTERVAL_SECONDS=3600

# -----------------------------------------------------------------------------
# Redis Configuration (可选 - 生产环境)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173