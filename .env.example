# =============================================================================
# China Travel A2A - Environment Configuration
# =============================================================================

# Server Configuration
SERVER_URL=localhost
ORCHESTRATOR_PORT=10000
ORCHESTRATOR_BIND_HOST=0.0.0.0

# Agent Ports
CLARIFIER_AGENT_PORT=10007
WEATHER_AGENT_PORT=10008
TRANSPORT_AGENT_PORT=10009
ATTRACTION_AGENT_PORT=10010
FOOD_AGENT_PORT=10011
HOTEL_AGENT_PORT=10012
GUIDE_AGENT_PORT=10013
AGGREGATOR_AGENT_PORT=10014
BUDGET_AGENT_PORT=10015
ROUTE_AGENT_PORT=10016
VALIDATOR_AGENT_PORT=10017
BOOKING_AGENT_PORT=10018

# LLM Configuration (DashScope / Qwen)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_MODEL=qwen-plus

# MCP Services
# 墨迹天气 MCP
MOJI_WEATHER_MCP_URL=https://mcp.modelscope.cn/api/v1/servers/@moji/moji-weather-mcp

# 12306 MCP
RAILWAY_12306_MCP_URL=https://mcp.modelscope.cn/api/v1/servers/@luyuhan520/12306-mcp

# 飞常准航空 MCP
VARIFLIGHT_MCP_URL=https://mcp.modelscope.cn/api/v1/servers/@luyuhan520/variflight-mcp

# 高德地图 MCP
AMAP_MCP_URL=https://mcp.modelscope.cn/api/v1/servers/@luyuhan520/amap-mcp
AMAP_API_KEY=your_amap_api_key

# 小红书 MCP (自研)
XIAOHONGSHU_MCP_URL=http://localhost:8080

# AI支付 MCP (阿里百炼)
BAILIAN_PAYMENT_MCP_URL=https://mcp.modelscope.cn/api/v1/servers/@aliyun/bailian-payment-mcp

# Session Configuration
SESSION_TTL_SECONDS=86400
SESSION_CLEANUP_INTERVAL_SECONDS=3600

# Redis Configuration (Optional, for production)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Frontend Configuration
FRONTEND_URL=http://localhost:5173